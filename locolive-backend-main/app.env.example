DB_DRIVER=postgres
# Docker Compose: use service name 'postgres' | Render: use fromDatabase property
DB_SOURCE=postgresql://postgres:password@postgres:5432/privacy_social?sslmode=disable
SERVER_ADDRESS=0.0.0.0:8080
# Docker Compose: use service name 'redis' | Render: will be injected automatically
REDIS_ADDRESS=redis://redis:6379
# CRITICAL: Change this to a strong random 32+ character secret in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_STRONG_32_CHAR_SECRET
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudflare R2 (or compatible S3) storage for media uploads
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_r2_bucket_name

EXPO_REDIRECT_URL=exp://127.0.0.1:8081/--/google-auth

# Email / Reset Password (SMTP / Gmail)
# Use a 16-digit App Password for Gmail
EMAIL_SENDER_NAME=Locolive
EMAIL_SENDER_ADDRESS=mouryaneha53@gmail.com
EMAIL_SENDER_PASSWORD=wekz nmbb dhfv ilkx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Set this to your deployed frontend URL in production
FRONTEND_URL=https://your-frontend.vercel.app

ENVIRONMENT=production

# HTTPS Configuration (Required for Production)
TLS_CERT_FILE=./certs/fullchain.pem
TLS_KEY_FILE=./certs/privkey.pem
FORCE_HTTPS=true
