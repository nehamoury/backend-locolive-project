# ============================================
# VPS PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env and generate ALL secure values
# ============================================

# ============================================
# CRITICAL SECURITY - GENERATE STRONG SECRETS
# ============================================

# JWT Secret - Generate: openssl rand -hex 32
# Min 32 chars. This signs all authentication tokens.
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_STRING

# Database Password - Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_DB_PASSWORD

# Redis Password - Generate: openssl rand -base64 32  
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_REDIS_PASSWORD

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_DRIVER=postgres
POSTGRES_USER=postgres
POSTGRES_DB=privacy_social
# Internal Docker network connection (secure, no SSL needed inside network)
DB_SOURCE=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/privacy_social?sslmode=disable

# ============================================
# REDIS CONFIGURATION
# ============================================
# Internal Docker network with password auth
REDIS_ADDRESS=redis://:${REDIS_PASSWORD}@redis:6379

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_ADDRESS=0.0.0.0:8080
GIN_MODE=release

# Token durations
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h

# ============================================
# TLS / HTTPS CONFIGURATION (VPS PRODUCTION)
# ============================================
# Option 1: Use Caddy/Nginx reverse proxy (RECOMMENDED)
#   - Leave these empty, bind app to 127.0.0.1:8081
#   - Proxy handles HTTPS via Let's Encrypt
# 
# Option 2: App-level TLS (if no reverse proxy)
#   - Uncomment and set paths to Let's Encrypt certs
# TLS_CERT_FILE=/app/certs/fullchain.pem
# TLS_KEY_FILE=/app/certs/privkey.pem

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 / S3 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=

# SendGrid Email
SENDGRID_API_KEY=
FROM_EMAIL=no-reply@locolive.io

# ============================================
# CORS / FRONTEND
# ============================================
# Your production domain
FRONTEND_URL=https://locolive.io
