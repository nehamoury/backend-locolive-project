DB_DRIVER=postgres
DB_SOURCE=postgresql://postgres:neha1234@localhost:5432/privacy_social?sslmode=disable
SERVER_ADDRESS=0.0.0.0:8080
REDIS_ADDRESS=redis://:neha_redis_pass@localhost:6379

JWT_SECRET=your_32_character_strong_secret
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudflare R2 (or compatible S3) storage for media uploads
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_r2_bucket_name

# Email / Reset Password (SMTP / Gmail)
EMAIL_SENDER_NAME=Locolive
EMAIL_SENDER_ADDRESS=your-email@gmail.com
EMAIL_SENDER_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Set this to your deployed frontend URL in production
FRONTEND_URL=https://locolive.appnity.co.in
ENVIRONMENT=production
